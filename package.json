{
  "name": "format-package",
  "version": "7.0.1",
  "description": "Sensible formatting and ordering of package.json",
  "license": "MIT",
  "engines": {
    "node": ">=22.18.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/camacho/format-package.git"
  },
  "bugs": {
    "url": "https://github.com/camacho/format-package/issues"
  },
  "homepage": "https://github.com/camacho/format-package#readme",
  "author": "Patrick Camacho <patrick@daftdevelopers.com>",
  "contributors": [
    "Alexandre Germain (https://gerkindev.github.io/devblog/)",
    "Peter Chanthamynavong <peterkc@gmail.com>"
  ],
  "keywords": [
    "format",
    "order",
    "organize",
    "package",
    "package.json",
    "prettier",
    "prettify"
  ],
  "bin": "build/cli/index.js",
  "type": "module",
  "main": "build/lib/index.js",
  "files": [
    "build",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm run clean-build",
    "build": "tsc",
    "postbuild": "chmod +x ./build/cli/index.js",
    "clean": "npm-run-all clean-build clean-packages",
    "clean-build": "rimraf ./build",
    "clean-packages": "rimraf ./node_modules",
    "dev": "node ./src/cli/index.ts",
    "docs": "node ./scripts/markdown.ts",
    "format": "npm-run-all format-package format-source",
    "format-docs": "prettier --write '**/*.md'",
    "format-package": "node ./src/cli/index.ts -w package.json",
    "format-source": "prettier \"**/**{js,json,ts,yml}\" --write",
    "gamut": "npm-run-all reset format lint type-check test build start",
    "lint": "eslint .",
    "prepare": "husky install",
    "prepublishOnly": "npm run gamut",
    "reset": "npm run clean && npm install",
    "start": "node ./build/cli/index.js",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "watch": "node --watch ./src/cli/index.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint",
      "prettier --write"
    ],
    "*.{yml,md,json}": [
      "prettier --write"
    ],
    "**/package.json": [
      "npm run format-package"
    ]
  },
  "overrides": {
    "markdown-magic-engines": {
      "markdown-magic": "$markdown-magic"
    },
    "markdown-magic-install-command": {
      "markdown-magic": "$markdown-magic"
    },
    "markdown-magic-package-scripts": {
      "markdown-magic": "$markdown-magic"
    },
    "markdown-magic-prettier": {
      "markdown-magic": "$markdown-magic",
      "prettier": "$prettier"
    }
  },
  "dependencies": {
    "@hapi/joi": "^15.1.1",
    "cosmiconfig": "^5.2.1",
    "fs-extra": "^10.0.0",
    "globby": "^11.0.4",
    "json5": "^2.2.0",
    "resolve-from": "^5.0.0",
    "sort-scripts": "^1.0.1",
    "yargs": "^17.3.1"
  },
  "peerDependencies": {
    "prettier": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cosmiconfig": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/globby": "^9.1.0",
    "@types/hapi__joi": "^15.0.3",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "execa": "^5.1.1",
    "globals": "^17.6.0",
    "husky": "^7.0.0",
    "install-deps-postmerge": "^1.0.5",
    "lint-staged": "^12.1.4",
    "markdown-magic": "^1.0.0",
    "markdown-magic-engines": "^1.0.2",
    "markdown-magic-install-command": "^1.3.1",
    "markdown-magic-package-scripts": "^1.2.1",
    "markdown-magic-prettier": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
